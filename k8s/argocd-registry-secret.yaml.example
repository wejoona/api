# =============================================================================
# Registry Credentials for ArgoCD Image Updater
# =============================================================================
# IMPORTANT: Do NOT commit this file with real credentials
# Apply directly to cluster: kubectl apply -f argocd-registry-secret.yaml
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: wejoona-registry-credentials
  namespace: argocd
type: kubernetes.io/dockerconfigjson
data:
  # Base64 encoded docker config JSON
  # Generate with: echo -n '{"auths":{"registry.wejoona.com":{"auth":"BASE64_USER:PASS"}}}' | base64
  .dockerconfigjson: <BASE64_ENCODED_DOCKER_CONFIG>
