# Circuit Breaker Configuration for External Services

# ============================================
# Circle API (USDC Transfers)
# ============================================
# Number of consecutive failures before opening circuit
RESILIENCE_CIRCLE_FAILURE_THRESHOLD=5

# Time in milliseconds to wait before testing recovery
RESILIENCE_CIRCLE_RESET_TIMEOUT=30000

# Request timeout in milliseconds
RESILIENCE_CIRCLE_REQUEST_TIMEOUT=5000

# Enable/disable circuit breaker for Circle
RESILIENCE_CIRCLE_ENABLED=true

# ============================================
# Yellow Card API (Mobile Money On/Off-ramp)
# ============================================
# Lower threshold due to higher latency
RESILIENCE_YELLOWCARD_FAILURE_THRESHOLD=3

# Longer reset timeout for mobile money operations
RESILIENCE_YELLOWCARD_RESET_TIMEOUT=60000

# Longer timeout for mobile money processing
RESILIENCE_YELLOWCARD_REQUEST_TIMEOUT=10000

# Enable/disable circuit breaker for Yellow Card
RESILIENCE_YELLOWCARD_ENABLED=true

# ============================================
# Twilio API (SMS Notifications)
# ============================================
# SMS is non-critical, can tolerate more failures
RESILIENCE_TWILIO_FAILURE_THRESHOLD=5

# Medium reset timeout
RESILIENCE_TWILIO_RESET_TIMEOUT=45000

# SMS typically responds quickly
RESILIENCE_TWILIO_REQUEST_TIMEOUT=8000

# Enable/disable circuit breaker for Twilio
RESILIENCE_TWILIO_ENABLED=true

# ============================================
# Blnk API (Ledger Operations)
# ============================================
# Critical service - fail fast
RESILIENCE_BLNK_FAILURE_THRESHOLD=3

# Shorter reset timeout for critical service
RESILIENCE_BLNK_RESET_TIMEOUT=20000

# Quick timeout for ledger operations
RESILIENCE_BLNK_REQUEST_TIMEOUT=5000

# Enable/disable circuit breaker for Blnk
RESILIENCE_BLNK_ENABLED=true

# ============================================
# Production Recommendations
# ============================================
# Circle: 5 failures, 30s reset, 5s timeout
# Yellow Card: 3 failures, 60s reset, 10s timeout
# Twilio: 5 failures, 45s reset, 8s timeout
# Blnk: 3 failures, 20s reset, 5s timeout

# ============================================
# Staging/Development Recommendations
# ============================================
# Use higher thresholds and longer timeouts
# for more lenient behavior during development
# Circle: 10 failures, 60s reset, 10s timeout
# Yellow Card: 5 failures, 90s reset, 15s timeout
# Twilio: 10 failures, 60s reset, 10s timeout
# Blnk: 5 failures, 30s reset, 8s timeout
