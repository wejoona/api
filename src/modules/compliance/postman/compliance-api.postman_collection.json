            "url": {
              "raw": "{{base_url}}/compliance/alerts/:alertId/resolve",
              "host": ["{{base_url}}"],
              "path": ["compliance", "alerts", ":alertId", "resolve"],
              "variable": [
                {
                  "key": "alertId",
                  "value": ""
                }
              ]
            }
