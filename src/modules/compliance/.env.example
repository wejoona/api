# ==========================================
# BCEAO Compliance Engine Configuration
# ==========================================
#
# Central Bank of West African States (BCEAO) compliance settings
# for JoonaPay USDC Wallet operating in WAEMU/UEMOA region
#
# Required for production deployment in:
# CI (Ivory Coast), SN (Senegal), ML (Mali), BF (Burkina Faso),
# BJ (Benin), TG (Togo), NE (Niger), GW (Guinea-Bissau)
# ==========================================

# Master Switch
# Enable/disable BCEAO compliance features
# Set to 'false' only in development/testing environments
BCEAO_COMPLIANCE_ENABLED=true

# ==========================================
# Transaction Thresholds
# ==========================================

# Large transaction reporting threshold (in XOF)
# BCEAO requires reporting transactions > 1,000,000 XOF (~$1,600 USD)
LARGE_TRANSACTION_THRESHOLD=1000000

# Daily transaction velocity threshold (transactions per hour)
# Exceeding this triggers velocity anomaly investigation
# Recommended: 5 for retail users, 10 for business accounts
AUTO_FLAG_VELOCITY_THRESHOLD=5

# Structuring detection time window (hours)
# Time period to aggregate transactions for smurfing detection
# BCEAO standard: 24 hours
STRUCTURING_TIME_WINDOW=24

# ==========================================
# Reporting Configuration
# ==========================================

# Daily report generation time (24-hour format, WAT timezone)
# BCEAO requires daily reports by 09:00 WAT
# Generate at midnight to allow morning review
DAILY_REPORT_TIME=00:00

# Report retention period (days)
# BCEAO mandates 7 years (2,555 days)
# DO NOT REDUCE BELOW 2555 IN PRODUCTION
REPORT_RETENTION_DAYS=2555

# Cross-border transaction alerts
# Alert on all transactions outside WAEMU zone
CROSS_BORDER_ALERT_ENABLED=true

# ==========================================
# SAR Configuration
# ==========================================

# Auto-generate SARs for critical risk
# If true, automatically create SAR for risk scores >= threshold
# If false, create alerts requiring manual SAR creation
# Recommended: false (manual review before SAR filing)
AUTO_GENERATE_SAR=false

# Risk score threshold for auto-SAR generation (0-100)
# Only applies if AUTO_GENERATE_SAR=true
SAR_AUTO_GENERATION_THRESHOLD=85

# ==========================================
# Exchange Rates
# ==========================================

# XOF to USDC exchange rate
# Update regularly from exchange rate service
# Current approximate: 1 USDC ≈ 600 XOF
XOF_TO_USDC_RATE=600

# ==========================================
# BCEAO API Integration (Future)
# ==========================================

# BCEAO regulatory reporting API
# Contact BCEAO for production credentials
BCEAO_API_URL=https://api.bceao.int
BCEAO_API_KEY=your_bceao_api_key_here
BCEAO_INSTITUTION_ID=your_institution_id_here

# BCEAO API timeout (milliseconds)
BCEAO_API_TIMEOUT=30000

# ==========================================
# PEP & Sanctions Screening (Optional)
# ==========================================

# Enable Politically Exposed Person screening
PEP_SCREENING_ENABLED=false

# PEP screening provider
# Options: 'world-check', 'dow-jones', 'comply-advantage', 'lexis-nexis'
PEP_SCREENING_PROVIDER=world-check

# PEP screening API credentials
PEP_SCREENING_API_URL=
PEP_SCREENING_API_KEY=
PEP_SCREENING_API_SECRET=

# Sanctions list screening
SANCTIONS_SCREENING_ENABLED=false

# Sanctions list sources (comma-separated)
# Options: 'ofac', 'un', 'eu', 'uk'
SANCTIONS_LISTS=ofac,un,eu

# ==========================================
# Alert Configuration
# ==========================================

# Alert notification channels (comma-separated)
# Options: 'email', 'sms', 'slack', 'dashboard'
COMPLIANCE_ALERT_CHANNELS=email,dashboard

# Email addresses for compliance officers (comma-separated)
COMPLIANCE_OFFICER_EMAILS=compliance@joonapay.com,aml-officer@joonapay.com

# Slack webhook for critical alerts
COMPLIANCE_SLACK_WEBHOOK=

# ==========================================
# Advanced Settings
# ==========================================

# Enable machine learning-based risk scoring
# Requires ML model training and deployment
ML_RISK_SCORING_ENABLED=false

# ML model endpoint
ML_RISK_MODEL_URL=

# Network analysis (transaction graph analysis)
# Requires graph database (Neo4j)
NETWORK_ANALYSIS_ENABLED=false

# Behavioral biometrics
# Analyze transaction patterns and timing
BEHAVIORAL_ANALYSIS_ENABLED=false

# ==========================================
# Development/Testing
# ==========================================

# Mock BCEAO API responses (for testing)
BCEAO_USE_MOCK=true

# Reduced thresholds for testing
# DO NOT USE IN PRODUCTION
# LARGE_TRANSACTION_THRESHOLD=10000  # Lower for testing
# AUTO_FLAG_VELOCITY_THRESHOLD=3     # Lower for testing

# ==========================================
# Performance Tuning
# ==========================================

# Batch analysis chunk size
# Number of users to analyze per batch
BATCH_ANALYSIS_CHUNK_SIZE=100

# Alert deduplication window (minutes)
# Prevent duplicate alerts for same user/issue
ALERT_DEDUP_WINDOW=60

# Report generation timeout (seconds)
REPORT_GENERATION_TIMEOUT=300

# ==========================================
# Compliance Notes
# ==========================================
#
# 1. BCEAO FILING DEADLINES:
#    - Daily reports: Submit by 09:00 WAT next business day
#    - Monthly reports: Submit by 10th of following month
#    - SARs: File within 48 hours of detection
#
# 2. DATA RETENTION:
#    - Transaction records: 7 years
#    - Customer identification: 7 years after account closure
#    - Correspondence: 7 years
#    - Never delete archived compliance data
#
# 3. CONFIDENTIALITY:
#    - No tipping-off: Never inform users of SAR filing
#    - Restricted access: Only compliance officers
#    - Secure storage: Encrypt at rest
#
# 4. TRAINING:
#    - Staff must complete AML/CFT training annually
#    - Document all training sessions
#    - Update procedures based on BCEAO directives
#
# ==========================================
