# Sanctions Screening Configuration

# Provider Selection
# Options: 'mock' (development), 'complyadvantage', 'worldcheck', 'dowjones', 'bridger'
SANCTIONS_SCREENING_PROVIDER=mock

# Screening Thresholds
# Auto-block threshold (exact match) - 0-100
SANCTIONS_AUTO_BLOCK_THRESHOLD=95

# Manual review threshold (fuzzy match) - 0-100
SANCTIONS_REVIEW_THRESHOLD=70

# High-value transfer threshold (in base currency)
# Only screen transfers above this amount
SANCTIONS_HIGH_VALUE_THRESHOLD=10000

# ===================================
# ComplyAdvantage Configuration
# ===================================
# COMPLYADVANTAGE_API_KEY=your-api-key-here
# COMPLYADVANTAGE_BASE_URL=https://api.complyadvantage.com
# COMPLYADVANTAGE_FUZZINESS=0.8

# ===================================
# Refinitiv World-Check Configuration
# ===================================
# WORLDCHECK_API_KEY=your-api-key
# WORLDCHECK_GROUP_ID=your-group-id
# WORLDCHECK_BASE_URL=https://api-worldcheck.refinitiv.com/v2

# ===================================
# Dow Jones Configuration
# ===================================
# DOWJONES_API_KEY=your-api-key
# DOWJONES_CLIENT_ID=your-client-id

# ===================================
# LexisNexis Bridger Configuration
# ===================================
# BRIDGER_API_KEY=your-api-key

# ===================================
# Caching Configuration
# ===================================
# Cache screening results to reduce API costs
# SCREENING_CACHE_TTL=86400  # 24 hours in seconds
# SCREENING_CACHE_ENABLED=true

# ===================================
# Rate Limiting
# ===================================
# SCREENING_RATE_LIMIT=100  # Max requests per minute
# SCREENING_RATE_LIMIT_WINDOW=60000  # 1 minute in milliseconds

# ===================================
# Monitoring and Alerts
# ===================================
# Alert when provider health check fails
# SCREENING_ALERT_ON_FAILURE=true
# SCREENING_ALERT_EMAIL=compliance@joonapay.com
# SCREENING_ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
