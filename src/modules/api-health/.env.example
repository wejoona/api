# API Health Monitoring Configuration

# Circle API
CIRCLE_API_URL=https://api.circle.com
CIRCLE_API_KEY=your_circle_api_key_here

# Yellow Card API
YELLOW_CARD_API_URL=https://sandbox.api.yellowcard.io
