# ============================================
# JOONAPAY USDC WALLET API - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values

# --------------------------------------------
# SERVER
# --------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Public URL for webhooks (Twilio, Circle, Yellow Card)
APP_PUBLIC_URL=http://localhost:3000

# --------------------------------------------
# DATABASE (PostgreSQL)
# --------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=usdc_wallet
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# --------------------------------------------
# CACHE (Redis)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --------------------------------------------
# AUTHENTICATION (JWT) - SECURITY CRITICAL
# --------------------------------------------
# IMPORTANT: Generate secure random secrets for production!
# Use: openssl rand -base64 48
# Minimum 32 characters required
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_generate_different_secret_for_refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# CORS (Allowed Origins)
# --------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# --------------------------------------------
# CIRCLE PROVIDER (Identity, Wallets, Transfers)
# --------------------------------------------
# Get credentials at: https://developers.circle.com
# Documentation: https://developers.circle.com/w3s/docs
CIRCLE_API_URL=https://api.circle.com
# Test API Key (sandbox only - do not use in production)
CIRCLE_API_KEY=TEST_API_KEY:f5aa40eeda829225e967032ea2462f23:21a5db8c89b336320a3809eaa65ec059
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
# Default blockchain for USDC: MATIC (Polygon), ETH, SOL, AVAX
CIRCLE_DEFAULT_BLOCKCHAIN=MATIC
CIRCLE_WEBHOOK_SECRET=
# Set to 'true' to use mock mode without real API calls
CIRCLE_USE_MOCK=true

# --------------------------------------------
# YELLOW CARD PROVIDER (On-ramp/Off-ramp for Africa)
# --------------------------------------------
# Get credentials at: https://dashboard.yellowcard.io
# Documentation: https://docs.yellowcard.io
# Yellow Card is used ONLY for XOF ↔ USDC conversion via Mobile Money
YELLOW_CARD_API_URL=https://sandbox.yellowcard.io
YELLOW_CARD_API_KEY=
YELLOW_CARD_SECRET_KEY=
YELLOW_CARD_WEBHOOK_SECRET=
# Set to 'true' to use mock mode without real API calls
YELLOW_CARD_USE_MOCK=true

# --------------------------------------------
# FIREBASE CLOUD MESSAGING (Push Notifications)
# --------------------------------------------
# Get credentials from Firebase Console
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# Set to 'true' to use mock mode
FCM_USE_MOCK=true

# --------------------------------------------
# SMS PROVIDER (for OTP)
# --------------------------------------------
# Options: 'mock', 'twilio', 'africas_talking'
SMS_PROVIDER=mock
SMS_SENDER_ID=JoonaPay

# --------------------------------------------
# TWILIO SMS (if SMS_PROVIDER=twilio)
# --------------------------------------------
# Get credentials at: https://www.twilio.com/console
# Documentation: https://www.twilio.com/docs/sms
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here

# Use EITHER phone number OR messaging service SID
TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twilio Advanced Configuration (Optional - has defaults)
TWILIO_MAX_RETRIES=3
TWILIO_INITIAL_RETRY_DELAY_MS=1000
TWILIO_MAX_RETRY_DELAY_MS=10000
TWILIO_RATE_LIMIT_PER_MINUTE=5
TWILIO_RATE_LIMIT_PER_HOUR=10
TWILIO_VALIDATE_SIGNATURES=true

# --------------------------------------------
# AFRICA'S TALKING SMS (if SMS_PROVIDER=africas_talking)
# --------------------------------------------
# Get credentials at: https://account.africastalking.com
# AT_USERNAME=your_username
# AT_API_KEY=your_api_key

# --------------------------------------------
# OTP SETTINGS
# --------------------------------------------
OTP_EXPIRES_IN=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
# Development mode - use fixed OTP (bypass SMS provider)
OTP_USE_DEV_OTP=false
OTP_DEV_OTP=123456
# Enable debug logging (dev only - logs OTP codes)
OTP_ENABLE_DEBUG_LOGGING=false

# --------------------------------------------
# RATE LIMITING
# --------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --------------------------------------------
# APP SETTINGS
# --------------------------------------------
DEFAULT_COUNTRY=CI
DEFAULT_CURRENCY=USDC
# Supported UEMOA countries + USA
SUPPORTED_COUNTRIES=CI,SN,ML,BF,BJ,TG,NE,US
SUPPORTED_CURRENCIES=USDC,XOF,USD

# Transaction limits
MIN_DEPOSIT_AMOUNT=500
MAX_DEPOSIT_AMOUNT=1000000
MIN_TRANSFER_AMOUNT=1
MAX_TRANSFER_AMOUNT=10000

# Fee settings
# Internal P2P transfers are FREE
INTERNAL_TRANSFER_FEE_PERCENT=0
# External blockchain transfers (0.5%)
EXTERNAL_TRANSFER_FEE_PERCENT=0.5

# --------------------------------------------
# AWS S3 (Document Storage for KYC)
# --------------------------------------------
# Get credentials from AWS Console (IAM)
# Create S3 bucket with private access for KYC documents
# Recommended bucket policy: restrict access to only API server
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=joonapay-kyc-documents
