# ============================================
# JOONAPAY USDC WALLET API - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values
# SECURITY: Never commit .env files with real credentials to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Public URL for webhooks (Twilio, Circle, Yellow Card)
# In production: https://usdc-wallet-api.wejoona.com
APP_PUBLIC_URL=http://localhost:3000

# Application version (used for APM/tracing)
APP_VERSION=1.0.0

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Primary database connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=usdc_wallet
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# IMPORTANT: Never enable synchronize in production - use migrations instead
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# ============================================
# CACHE (Redis)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# AUTHENTICATION (JWT) - SECURITY CRITICAL
# ============================================
# IMPORTANT: Generate secure random secrets for production!
# Use: openssl rand -base64 48
# Minimum 32 characters required for each secret

# Access token secret (short-lived tokens)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# Refresh token secret (MUST be different from JWT_SECRET)
JWT_REFRESH_SECRET=CHANGE_ME_generate_different_secret_for_refresh

# Token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS (Allowed Origins)
# ============================================
# Comma-separated list of allowed origins
# Production: Only include your actual frontend domains
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# ============================================
# CIRCLE PROVIDER (Identity, Wallets, Transfers)
# ============================================
# Documentation: https://developers.circle.com/w3s/docs
# Get credentials at: https://developers.circle.com

CIRCLE_API_URL=https://api.circle.com

# API Key - Get from Circle Console
# Test API Key format: TEST_API_KEY:xxx:xxx
CIRCLE_API_KEY=

# Entity Secret (encrypted) - Required for wallet operations
CIRCLE_ENTITY_SECRET=

# Wallet Set ID - Created in Circle Console
CIRCLE_WALLET_SET_ID=

# Default blockchain for USDC transfers
# Options: MATIC (Polygon - recommended for low fees), ETH, SOL, AVAX
CIRCLE_DEFAULT_BLOCKCHAIN=MATIC

# Webhook secret for verifying Circle webhook signatures
CIRCLE_WEBHOOK_SECRET=

# Enable Circle Compliance Engine (enterprise feature)
# Requires separate enablement from Circle
CIRCLE_COMPLIANCE_ENABLED=false

# Set to 'true' to use mock mode without real API calls
CIRCLE_USE_MOCK=true

# ============================================
# YELLOW CARD PROVIDER (On-ramp/Off-ramp for Africa)
# ============================================
# Documentation: https://docs.yellowcard.io
# Get credentials at: https://dashboard.yellowcard.io
# Yellow Card is used ONLY for XOF <-> USDC conversion via Mobile Money

YELLOW_CARD_API_URL=https://sandbox.yellowcard.io
YELLOW_CARD_API_KEY=
YELLOW_CARD_SECRET_KEY=
YELLOW_CARD_WEBHOOK_SECRET=

# Set to 'true' to use mock mode without real API calls
YELLOW_CARD_USE_MOCK=true

# ============================================
# BLNK FINANCE (Ledger/Accounting)
# ============================================
# Documentation: https://docs.blnkfinance.com
# Double-entry ledger for transaction accounting
# Production: https://blnk.wejoona.com

BLNK_URL=http://localhost:5001
BLNK_API_KEY=

# ============================================
# SMS PROVIDER (for OTP)
# ============================================
# Provider options: 'mock', 'twilio', 'africas_talking'
SMS_PROVIDER=mock
SMS_SENDER_ID=JoonaPay

# Legacy SMS settings (if not using Twilio directly)
SMS_API_KEY=
SMS_API_SECRET=

# ============================================
# TWILIO SMS/VOICE (if SMS_PROVIDER=twilio)
# ============================================
# Documentation: https://www.twilio.com/docs/sms
# Get credentials at: https://www.twilio.com/console

TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here

# Use EITHER phone number OR messaging service SID (not both)
TWILIO_FROM_NUMBER=+1234567890
# TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Set to 'true' to use mock mode
TWILIO_USE_MOCK=true

# Twilio Advanced Configuration (Optional - has sensible defaults)
TWILIO_MAX_RETRIES=3
TWILIO_INITIAL_RETRY_DELAY_MS=1000
TWILIO_MAX_RETRY_DELAY_MS=10000
TWILIO_RATE_LIMIT_PER_MINUTE=5
TWILIO_RATE_LIMIT_PER_HOUR=10
TWILIO_VALIDATE_SIGNATURES=true

# ============================================
# AFRICA'S TALKING SMS (if SMS_PROVIDER=africas_talking)
# ============================================
# Documentation: https://developers.africastalking.com
# Get credentials at: https://account.africastalking.com
# AT_USERNAME=your_username
# AT_API_KEY=your_api_key

# ============================================
# OTP SETTINGS
# ============================================
# OTP expiration time in seconds (default: 5 minutes)
OTP_EXPIRES_IN=300

# Number of digits in OTP code
OTP_LENGTH=6

# Maximum failed attempts before lockout
OTP_MAX_ATTEMPTS=3

# Development mode - use fixed OTP (bypasses SMS provider)
# SECURITY: Only enable in development!
OTP_USE_DEV=false
OTP_DEV_CODE=123456

# Enable debug logging (SECURITY: Only in development - logs OTP codes!)
OTP_DEBUG_LOGGING=false

# Legacy OTP settings (for backwards compatibility)
OTP_USE_DEV_OTP=false
OTP_DEV_OTP=123456
OTP_ENABLE_DEBUG_LOGGING=false

# ============================================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# ============================================
# Get credentials from Firebase Console > Project Settings > Service Accounts
# Download the private key JSON and extract these values

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Note: Private key should include \n for newlines
FCM_PRIVATE_KEY=

# Set to 'true' to use mock mode
FCM_USE_MOCK=true

# ============================================
# KYC VERIFICATION SETTINGS
# ============================================
# KYC provider options: 'mock', 'onfido', 'jumio', 'sumsub'
KYC_PROVIDER=mock

# Auto-approval based on verification score
KYC_AUTO_APPROVAL_ENABLED=true

# Score thresholds (0-100)
# >= threshold = auto-approve, <= reject_threshold = auto-reject
# Between = manual review required
KYC_AUTO_APPROVAL_THRESHOLD=80
KYC_AUTO_REJECT_THRESHOLD=40

# ============================================
# AWS S3 (Document Storage for KYC)
# ============================================
# Get credentials from AWS Console > IAM > Users
# Create S3 bucket with private access for KYC documents
# Recommended bucket policy: restrict access to only API server IP

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=joonapay-kyc-documents

# Set to 'true' to use mock mode (local file storage)
AWS_USE_MOCK=true

# ============================================
# RATE LIMITING
# ============================================
# Rate limit window in seconds
RATE_LIMIT_TTL=60

# Maximum requests per window
RATE_LIMIT_MAX=100

# ============================================
# APP SETTINGS - WEST AFRICAN CONTEXT
# ============================================
# Default country code (ISO 3166-1 alpha-2)
# CI = Cote d'Ivoire
DEFAULT_COUNTRY=CI

# Default currency for transactions
DEFAULT_CURRENCY=USDC

# Supported UEMOA countries + USA
# CI=Cote d'Ivoire, SN=Senegal, ML=Mali, BF=Burkina Faso
# BJ=Benin, TG=Togo, NE=Niger, US=United States
SUPPORTED_COUNTRIES=CI,SN,ML,BF,BJ,TG,NE,US

# Supported currencies
SUPPORTED_CURRENCIES=USDC,XOF,USD

# ============================================
# TRANSACTION LIMITS
# ============================================
# Deposit limits (in XOF)
MIN_DEPOSIT_AMOUNT=500
MAX_DEPOSIT_AMOUNT=1000000

# Transfer limits (in USDC)
MIN_TRANSFER_AMOUNT=1
MAX_TRANSFER_AMOUNT=10000

# ============================================
# FEE SETTINGS
# ============================================
# Internal P2P transfers (wallet to wallet) - FREE
INTERNAL_TRANSFER_FEE_PERCENT=0

# External blockchain transfers
EXTERNAL_TRANSFER_FEE_PERCENT=0.5

# ============================================
# BCEAO COMPLIANCE ENGINE
# ============================================
# Central Bank of West African States regulatory compliance
# Required for operation in UEMOA zone

# Master switch for BCEAO compliance features
BCEAO_COMPLIANCE_ENABLED=true

# Large transaction reporting threshold (XOF)
# 1,000,000 XOF ~ $1,600 USD - requires reporting to BCEAO
LARGE_TRANSACTION_THRESHOLD=1000000

# Daily report generation time (24-hour format, WAT timezone)
DAILY_REPORT_TIME=00:00

# Report retention period in days (BCEAO requires 7 years = 2555 days)
REPORT_RETENTION_DAYS=2555

# AML/CFT velocity threshold (transactions per hour)
# Exceeding this triggers velocity anomaly alert
AUTO_FLAG_VELOCITY_THRESHOLD=5

# Structuring detection time window (hours)
STRUCTURING_TIME_WINDOW=24

# Cross-border transaction alerts
CROSS_BORDER_ALERT_ENABLED=true

# Suspicious Activity Reports (SAR)
AUTO_GENERATE_SAR=false
SAR_AUTO_GENERATION_THRESHOLD=85

# BCEAO API (when available for direct reporting)
BCEAO_API_URL=
BCEAO_API_KEY=
BCEAO_INSTITUTION_ID=

# Exchange rate for XOF to USDC conversion
XOF_TO_USDC_RATE=600

# PEP (Politically Exposed Person) screening
PEP_SCREENING_ENABLED=false
PEP_SCREENING_PROVIDER=

# ============================================
# APM (Application Performance Monitoring)
# ============================================
APM_ENABLED=false

# Provider options: 'newrelic', 'datadog', 'none'
APM_PROVIDER=none
APM_SERVICE_NAME=usdc-wallet

# ============================================
# DISTRIBUTED TRACING (OpenTelemetry + Jaeger)
# ============================================
# Enable/disable distributed tracing
TRACING_ENABLED=true

# Service identification
TRACING_SERVICE_NAME=usdc-wallet-api
TRACING_SERVICE_VERSION=1.0.0

# Jaeger collector endpoint (OTLP HTTP)
# Default assumes Jaeger all-in-one running locally
JAEGER_ENDPOINT=http://localhost:4318/v1/traces

# Sampling rate: 0.0 (none) to 1.0 (all)
# Production: Use lower rate (e.g., 0.1 = 10%) to reduce overhead
TRACING_SAMPLE_RATE=1.0

# Export traces to console for debugging
TRACING_EXPORT_CONSOLE=false

# Jaeger UI endpoint (for documentation/links)
JAEGER_UI_URL=http://localhost:16686

# ============================================
# VERIFY HQ (Identity Verification)
# ============================================
VERIFY_HQ_URL=http://localhost:3300
VERIFY_HQ_API_KEY=your-api-key-here

