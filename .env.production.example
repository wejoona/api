# =============================================================================
# JOONAPAY USDC WALLET API - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# SECURITY WARNING: Never commit this file with real values!
# Copy to .env.production and configure with secure values.
# All secrets should be managed via secrets manager (AWS Secrets Manager, etc.)
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL) - Use managed service (AWS RDS, Cloud SQL, etc.)
# -----------------------------------------------------------------------------
# Example: AWS RDS PostgreSQL
DATABASE_HOST=your-rds-instance.region.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=usdc_wallet_prod
DATABASE_USER=usdc_wallet_user
DATABASE_PASSWORD=<GENERATE_STRONG_PASSWORD_32_CHARS>
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_CONNECTION_TIMEOUT=10000

# SSL for production database (required for RDS)
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# -----------------------------------------------------------------------------
# CACHE (Redis) - Use managed service (AWS ElastiCache, Redis Cloud, etc.)
# -----------------------------------------------------------------------------
# Example: AWS ElastiCache Redis
REDIS_HOST=your-elasticache-cluster.region.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_AUTH_TOKEN>
REDIS_DB=0
REDIS_TLS=true

# -----------------------------------------------------------------------------
# AUTHENTICATION (JWT) - CRITICAL SECURITY
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 64
# Rotate every 90 days
JWT_SECRET=<GENERATE_WITH_OPENSSL_RAND_BASE64_64>
JWT_REFRESH_SECRET=<GENERATE_DIFFERENT_SECRET_WITH_OPENSSL>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS (Allowed Origins) - Production domains only
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://app.joonapay.com,https://dashboard.joonapay.com

# -----------------------------------------------------------------------------
# CIRCLE PROVIDER (Production Credentials)
# -----------------------------------------------------------------------------
# Get credentials at: https://console.circle.com
CIRCLE_API_URL=https://api.circle.com
CIRCLE_API_KEY=<YOUR_CIRCLE_API_KEY>
CIRCLE_ENTITY_SECRET=<YOUR_CIRCLE_ENTITY_SECRET>
CIRCLE_WALLET_SET_ID=<YOUR_WALLET_SET_ID>
CIRCLE_DEFAULT_BLOCKCHAIN=MATIC
CIRCLE_WEBHOOK_SECRET=<YOUR_CIRCLE_WEBHOOK_SECRET>
CIRCLE_USE_MOCK=false

# -----------------------------------------------------------------------------
# YELLOW CARD PROVIDER (Production Credentials)
# -----------------------------------------------------------------------------
# Get credentials at: https://dashboard.yellowcard.io
YELLOW_CARD_API_URL=https://api.yellowcard.io
YELLOW_CARD_API_KEY=<YOUR_YELLOW_CARD_API_KEY>
YELLOW_CARD_SECRET_KEY=<YOUR_YELLOW_CARD_SECRET_KEY>
YELLOW_CARD_WEBHOOK_SECRET=<YOUR_YELLOW_CARD_WEBHOOK_SECRET>
YELLOW_CARD_USE_MOCK=false

# -----------------------------------------------------------------------------
# FIREBASE CLOUD MESSAGING (Production)
# -----------------------------------------------------------------------------
# Get credentials from Firebase Console -> Project Settings -> Service Accounts
FCM_PROJECT_ID=joonapay-production
FCM_CLIENT_EMAIL=firebase-adminsdk@joonapay-production.iam.gserviceaccount.com
FCM_PRIVATE_KEY=<YOUR_FCM_PRIVATE_KEY_BASE64_ENCODED>
FCM_USE_MOCK=false

# -----------------------------------------------------------------------------
# SMS PROVIDER (Production)
# -----------------------------------------------------------------------------
# Recommended: Twilio or Africa's Talking for Africa coverage
SMS_PROVIDER=twilio
SMS_SENDER_ID=JoonaPay

# Twilio Configuration
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: Africa's Talking
# SMS_PROVIDER=africas_talking
# AT_USERNAME=<YOUR_AT_USERNAME>
# AT_API_KEY=<YOUR_AT_API_KEY>
# AT_SHORTCODE=<YOUR_AT_SHORTCODE>

# -----------------------------------------------------------------------------
# OTP SETTINGS (Production)
# -----------------------------------------------------------------------------
OTP_EXPIRES_IN=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# RATE LIMITING (Stricter for production)
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=60

# -----------------------------------------------------------------------------
# APP SETTINGS
# -----------------------------------------------------------------------------
DEFAULT_COUNTRY=CI
DEFAULT_CURRENCY=USDC
SUPPORTED_COUNTRIES=CI,SN,ML,BF,BJ,TG,NE,US
SUPPORTED_CURRENCIES=USDC,XOF,USD

# Transaction limits (in XOF for deposits, USDC for transfers)
MIN_DEPOSIT_AMOUNT=1000
MAX_DEPOSIT_AMOUNT=5000000
MIN_TRANSFER_AMOUNT=1
MAX_TRANSFER_AMOUNT=50000

# Fee settings
INTERNAL_TRANSFER_FEE_PERCENT=0
EXTERNAL_TRANSFER_FEE_PERCENT=0.5

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry Error Tracking (recommended)
SENTRY_DSN=<YOUR_SENTRY_DSN>
SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# AWS CONFIGURATION (if using AWS services)
# -----------------------------------------------------------------------------
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>

# S3 for file storage
AWS_S3_BUCKET=joonapay-prod-uploads
AWS_S3_REGION=eu-west-1

# -----------------------------------------------------------------------------
# SECURITY HEADERS
# -----------------------------------------------------------------------------
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# -----------------------------------------------------------------------------
# HEALTH CHECK
# -----------------------------------------------------------------------------
HEALTH_CHECK_PATH=/api/v1/health
HEALTH_CHECK_INTERVAL=30000
