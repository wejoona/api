{
  "name": "usdc-wallet",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r tsconfig-paths/register dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "verify:backend:mobile": "npm run build && npm test -- --runInBand && npm run test:contracts && npm run test:e2e -- --testPathPatterns=\"auth.controller|contact.controller|device.controller|session.controller|user-profile.controller|user-pin.controller|wallet.controller|transfer.controller|transaction.controller|notification.controller|notification-preferences.controller|monitoring.controller|feature-subscription.controller|feature-flag.controller|referral.controller|app-config.controller|health.controller|kyc.controller|kyc-verify.controller|liveness.controller|merchant.controller|payment-link.controller|card.controller|savings-pot.controller|bank-linking.controller|beneficiary.controller|bulk-payment.controller|recurring-transfer.controller|bill-payment.controller|deposits.controller|withdrawal.controller|business.controller|sub-business.controller|risk.controller|step-up.controller|security.controller|whitelisted-address.controller|export.controller\"",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e:watch": "jest --config ./test/jest-e2e.json --runInBand --watch",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --runInBand --coverage",
    "test:e2e:user-journey": "jest --config ./test/jest-e2e.json --runInBand --testPathPatterns=user-journey",
    "test:e2e:security": "jest --config ./test/jest-e2e.json --runInBand --testPathPatterns=security",
    "test:e2e:performance": "jest --config ./test/jest-e2e.json --runInBand --testPathPatterns=performance",
    "test:fuzzing": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand",
    "test:fuzzing:auth": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand --testPathPatterns=auth",
    "test:fuzzing:wallet": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand --testPathPatterns=wallet",
    "test:fuzzing:user": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand --testPathPatterns=user",
    "test:fuzzing:kyc": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand --testPathPatterns=kyc",
    "test:fuzzing:cov": "jest --config ./test/fuzzing/jest-fuzzing.json --runInBand --coverage",
    "test:contracts": "jest --config ./test/contracts/jest-contracts.json --runInBand",
    "test:contracts:cov": "jest --config ./test/contracts/jest-contracts.json --runInBand --coverage",
    "test:contracts:watch": "jest --config ./test/contracts/jest-contracts.json --runInBand --watch",
    "test:financial": "jest --config ./test/financial/jest-financial.json --runInBand",
    "test:financial:fees": "jest --config ./test/financial/jest-financial.json --runInBand --testPathPatterns=fee-calculations",
    "test:financial:rates": "jest --config ./test/financial/jest-financial.json --runInBand --testPathPatterns=exchange-rate",
    "test:financial:balance": "jest --config ./test/financial/jest-financial.json --runInBand --testPathPatterns=balance-operations",
    "test:financial:cov": "jest --config ./test/financial/jest-financial.json --runInBand --coverage",
    "test:benchmark": "jest --config ./test/benchmarks/jest-benchmark.json --runInBand",
    "test:benchmark:transactions": "jest --config ./test/benchmarks/jest-benchmark.json --runInBand --testPathPatterns=transaction-queries",
    "test:benchmark:users": "jest --config ./test/benchmarks/jest-benchmark.json --runInBand --testPathPatterns=user-queries",
    "test:benchmark:wallets": "jest --config ./test/benchmarks/jest-benchmark.json --runInBand --testPathPatterns=wallet-queries",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/data-source.ts",
    "schema:check:mobile": "ts-node -r tsconfig-paths/register scripts/check-mobile-dogfood-schema.ts",
    "seed:prod": "SEED_MODE=production ts-node -r tsconfig-paths/register src/database/seeds/seed-runner.ts",
    "seed:staging": "SEED_MODE=staging ts-node -r tsconfig-paths/register src/database/seeds/seed-runner.ts",
    "seed:demo": "SEED_MODE=demo ts-node -r tsconfig-paths/register src/database/seeds/seed-runner.ts",
    "load:auth": "k6 run load-tests/auth-load-test.js",
    "load:auth:smoke": "STAGES=smoke k6 run load-tests/auth-load-test.js",
    "load:auth:stress": "STAGES=stress k6 run load-tests/auth-load-test.js",
    "load:wallet": "k6 run load-tests/wallet-load-test.js",
    "load:wallet:prod": "BASE_URL=https://api.joonapay.com k6 run load-tests/wallet-load-test.js",
    "load:transfer": "k6 run load-tests/transfer-load-test.js",
    "load:transfer:load": "TEST_MODE=load k6 run load-tests/transfer-load-test.js",
    "load:kyc": "k6 run load-tests/kyc-load-test.js",
    "load:flow": "k6 run load-tests/full-flow-test.js",
    "load:spike": "k6 run load-tests/spike-test.js",
    "load:spike:extreme": "SPIKE_MULTIPLIER=20 k6 run load-tests/spike-test.js",
    "load:all": "npm run load:auth && npm run load:wallet && npm run load:transfer && npm run load:kyc && npm run load:flow && npm run load:spike",
    "load:reports": "open load-tests/reports/",
    "load-test": "cd scripts/load-tests && ./run-tests.sh user-journey",
    "load-test:stress": "cd scripts/load-tests && ./run-tests.sh stress",
    "sdk:generate": "cd sdk-gen && ./scripts/generate-all.sh",
    "sdk:generate:ts": "cd sdk-gen && ./scripts/generate-ts.sh",
    "sdk:generate:dart": "cd sdk-gen && ./scripts/generate-dart.sh",
    "sdk:watch": "cd sdk-gen && ./scripts/watch.sh",
    "sdk:validate": "cd sdk-gen && ./scripts/validate-spec.sh",
    "sdk:publish:ts": "cd sdk-gen && ./scripts/publish-ts.sh",
    "sdk:publish:dart": "cd sdk-gen && ./scripts/publish-dart.sh"
  },
  "dependencies": {
    "@apollo/server": "^5.3.0",
    "@aws-sdk/client-s3": "^3.540.0",
